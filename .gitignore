.DS_Store
backup/
bin/
db/
sui
main
tmp
.sync*
*.tar.gz

# Adapted from github/gitignore Go.gitignore + Node.gitignore

# Stage 1A repository layout placeholders
build/out/*
!build/out/.gitkeep
build/tmp/*
!build/tmp/.gitkeep
build/reports/*
!build/reports/.gitkeep
dist/*
!dist/release/
dist/release/*
!dist/release/.gitkeep
release/
!scripts/release/
!scripts/release/**

# Environment files
.env
.env.*
!.env.example
!.env.*.example
.env.local
.env.*.local

# Log files
*.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
.cache

# Windows build artifacts
*.exe
*.zip
b-ui-windows/
sui-*.exe
sui-*.zip
windows/sui-*.exe

# Frontend build artifacts
src/frontend/node_modules/
src/frontend/dist/
src/frontend/coverage/
src/frontend/.vite/
src/frontend/.pnpm-store/
src/frontend/.eslintcache
src/frontend/*.tsbuildinfo
src/frontend/vite.config.js.timestamp-*
src/frontend/vite.config.ts.timestamp-*
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.vite/
frontend/.pnpm-store/
frontend/.eslintcache
frontend/*.tsbuildinfo
frontend/vite.config.js.timestamp-*
frontend/vite.config.ts.timestamp-*

# Go / backend test artifacts
*.test
*.out
coverage.*
*.coverprofile
profile.cov
go.work
go.work.sum

# Root node_modules
node_modules/

# Claude Code
.claude/

# Editor directories and files
.idea
.vscode
.worktrees/
